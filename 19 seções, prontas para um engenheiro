```typescript
// src/lib/simulation/scadaEngine.ts
export interface Alarm {
  id: string;
  tagName: string;
  priority: 'CRITICAL' | 'HIGH' | 'MEDIUM' | 'LOW';
  message: string;
  triggeredAt: Date;
  acknowledgedAt?: Date;
  clearedAt?: Date;
  isActive: boolean;
}

export class ScadaEngine {
  private alarms: Map<string, Alarm> = new Map();
  private tags: Map<string, number | boolean> = new Map();

  setTag(name: string, value: number | boolean): void {
    this.tags.set(name, value);
  }

  getTag(name: string): number | boolean | undefined {
    return this.tags.get(name);
  }

  triggerAlarm(id: string, priority: Alarm['priority'], message: string): void {
    if (!this.alarms.has(id)) {
      this.alarms.set(id, {
        id, priority, message,
        tagName: id,
        triggeredAt: new Date(),
        isActive: true,
      });
    }
  }

  acknowledgeAlarm(id: string): void {
    const alarm = this.alarms.get(id);
    if (alarm) alarm.acknowledgedAt = new Date();
  }

  getActiveAlarms(): Alarm[] {
    return Array.from(this.alarms.values())
      .filter((a) => a.isActive)
      .sort((a, b) => {
        const priority = { CRITICAL: 0, HIGH: 1, MEDIUM: 2, LOW: 3 };
        return priority[a.priority] - priority[b.priority];
      });
  }
}
```

