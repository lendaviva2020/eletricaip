      messages: [
        { role: "system", content: systemPrompt },
        { role: "user", content: message }
      ],
      temperature: 0.2
    })
  });
  const resJson = await response.json();
  const fullText = resJson.choices?.[0]?.message?.content ?? "";

  // 6. Parsear resposta e extrair actions (se houver patch de diagrama)
  const { text, diagramPatch, normWarnings } = parseAIResponse(fullText);

  // 7. Decrementar créditos (operação atômica)
  await supabase.rpc('decrement_ai_credits', {
    p_user_id: user.id,
    p_credits: creditsNeeded,
  });

  // 8. Registrar operação
  await supabase.from('ai_operations').insert({
    user_id: user.id,
    project_id: projectId,
    operation_type: operationType,
    credits_used: creditsNeeded,
    prompt_summary: message.substring(0, 200),
    status: 'success',
  });

  return new Response(
