### Passo 3.2 — Editor Store (Zustand)
```typescript
// src/stores/editorStore.ts
import { create } from 'zustand';
import { temporal } from 'zundo'; // undo/redo via zundo
import {
  Node, Edge, Connection, addEdge, applyNodeChanges, applyEdgeChanges,
  NodeChange, EdgeChange, XYPosition, OnNodesChange, OnEdgesChange
} from '@xyflow/react';
import type { ComponentData, ConnectionData } from '@/types/diagram.types';

type ActiveModule = 'unifilar' | 'ladder' | 'fbd' | 'scada' | 'digital_twin' | 'plc' | 'simulation';
type ActiveTool = 'select' | 'power-wire' | 'control-wire' | 'signal-wire' | 'pan';

interface EditorState {
  // Módulo e projeto
  projectId: string | null;
  projectName: string;
  activeModule: ActiveModule;
  saveStatus: 'saved' | 'saving' | 'unsaved';
  activeTool: ActiveTool;

  // Canvas state
  nodes: Node<ComponentData>[];
  edges: Edge<ConnectionData>[];

  // Seleção
  selectedNodeId: string | null;

  // Ações
  setProjectId: (id: string) => void;
  setProjectName: (name: string) => void;
  setActiveModule: (module: ActiveModule) => void;
  setActiveTool: (tool: ActiveTool) => void;
  setSaveStatus: (status: 'saved' | 'saving' | 'unsaved') => void;
  setSelectedNodeId: (id: string | null) => void;

  // Canvas actions
  onNodesChange: (changes: NodeChange[]) => void;
  onEdgesChange: (changes: EdgeChange[]) => void;
  onConnect: (connection: Connection) => void;

  addNode: (typeKey: string, defaultProps: Record<string, unknown>, position: XYPosition) => void;
  updateNodeData: (nodeId: string, data: Partial<ComponentData>) => void;
  deleteSelected: () => void;

  // Persistência
  loadFromJSON: (data: Record<string, unknown>, module: ActiveModule) => void;
  toJSON: () => { nodes: Node[]; edges: Edge[] };
}

export const useEditorStore = create<EditorState>()(
  temporal(
    (set, get) => ({
      projectId: null,
      projectName: 'Novo Projeto',
      activeModule: 'unifilar',
      saveStatus: 'saved',
      activeTool: 'select',
      nodes: [],
      edges: [],
      selectedNodeId: null,

      setProjectId: (id) => set({ projectId: id }),
      setProjectName: (name) => set({ projectName: name }),
      setActiveModule: (module) => set({ activeModule: module }),
      setActiveTool: (tool) => set({ activeTool: tool }),
      setSaveStatus: (status) => set({ saveStatus: status }),
      setSelectedNodeId: (id) => set({ selectedNodeId: id }),

      onNodesChange: (changes) =>
        set((s) => ({ nodes: applyNodeChanges(changes, s.nodes) })),

      onEdgesChange: (changes) =>
        set((s) => ({ edges: applyEdgeChanges(changes, s.edges) })),

      onConnect: (connection) => {
        const { activeTool } = get();
        const type = activeTool === 'control-wire' ? 'control'
          : activeTool === 'signal-wire' ? 'signal'
          : 'power';

        set((s) => ({
          edges: addEdge({
            ...connection,
            type: 'electricEdge',
            data: { connectionType: type } as ConnectionData,
            animated: false,
          }, s.edges),
          saveStatus: 'unsaved',
        }));
      },

      addNode: (typeKey, defaultProps, position) => {
        const newNode: Node<ComponentData> = {
          id: `${typeKey}-${Date.now()}`,
          type: 'electricComponent',
          position,
          data: {
            typeKey,
            label: typeKey.toUpperCase().replace('_', '-'),
            props: defaultProps,
            isEnergized: false,
            hasFault: false,
          } as ComponentData,
        };
        set((s) => ({ nodes: [...s.nodes, newNode], saveStatus: 'unsaved' }));
      },

      updateNodeData: (nodeId, data) => {
        set((s) => ({
          nodes: s.nodes.map((n) =>
            n.id === nodeId ? { ...n, data: { ...n.data, ...data } } : n
          ),
          saveStatus: 'unsaved',
        }));
      },

      deleteSelected: () => {
        const { selectedNodeId } = get();
        if (!selectedNodeId) return;
        set((s) => ({
          nodes: s.nodes.filter((n) => n.id !== selectedNodeId),
          edges: s.edges.filter(
            (e) => e.source !== selectedNodeId && e.target !== selectedNodeId
          ),
          selectedNodeId: null,
          saveStatus: 'unsaved',
        }));
      },

      loadFromJSON: (data, _module) => {
        const raw = data as { nodes?: Node[]; edges?: Edge[] };
        set({
          nodes: raw.nodes ?? [],
          edges: raw.edges ?? [],
          saveStatus: 'saved',
        });
      },

      toJSON: () => {
        const { nodes, edges } = get();
        return { nodes, edges };
      },
    }),
    { limit: 50 } // Máximo 50 estados no histórico
  )
);
