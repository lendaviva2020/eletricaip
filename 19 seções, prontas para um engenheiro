    generate_diagram: 5,
    analyze_norm: 3,
    read_file: 3,
  };
  const creditsNeeded = creditCosts[operationType] ?? 1;

  if ((profile?.ai_credits ?? 0) < creditsNeeded) {
    return new Response(
      JSON.stringify({ error: 'INSUFFICIENT_CREDITS', creditsNeeded, creditsAvailable: profile?.ai_credits }),
      { status: 402, headers: { 'Content-Type': 'application/json' } }
    );
  }

  // 4. Construir system prompt com contexto do projeto
  const systemPrompt = buildNexusMindSystemPrompt(projectContext);

  // 5. Chamar DeepSeek API
