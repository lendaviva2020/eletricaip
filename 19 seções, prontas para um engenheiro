// src/components/editor/edges/ElectricEdge.tsx
import { memo } from 'react';
import { EdgeProps, getSmoothStepPath, EdgeLabelRenderer } from '@xyflow/react';
import type { ConnectionData } from '@/types/diagram.types';

const EDGE_COLORS = {
  power:   'var(--color-power)',
  control: 'var(--color-control)',
  signal:  'var(--color-signal)',
} as const;

const EDGE_WIDTHS = { power: 3, control: 1.5, signal: 1 };

export const ElectricEdge = memo(function ElectricEdge({
  sourceX, sourceY, targetX, targetY,
  sourcePosition, targetPosition,
  data, selected,
}: EdgeProps<ConnectionData>) {
  const connType = data?.connectionType ?? 'power';
  const color = EDGE_COLORS[connType];
  const width = EDGE_WIDTHS[connType];

  const [edgePath] = getSmoothStepPath({
    sourceX, sourceY, targetX, targetY,
    sourcePosition, targetPosition,
    borderRadius: 8,
  });

  return (
    <>
      <path
        d={edgePath}
        stroke={color}
        strokeWidth={selected ? width + 1 : width}
        fill="none"
        strokeDasharray={connType === 'signal' ? '5 3' : connType === 'control' ? '8 4' : undefined}
        opacity={selected ? 1 : 0.8}
        className="transition-all duration-200"
      />
      {/* Animação de fluxo durante simulação */}
      {data?.isSimulating && (
        <path
          d={edgePath}
          stroke={color}
          strokeWidth={width}
          fill="none"
          strokeDasharray="10 20"
          className="animate-[dash_1s_linear_infinite]"
          opacity={0.6}
        />
      )}
    </>
  );
});
