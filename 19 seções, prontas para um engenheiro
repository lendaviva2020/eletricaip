### Passo 9.2 — Função SQL: Decrementar Créditos (Atômica)
```sql
-- Evita race condition ao decrementar créditos
CREATE OR REPLACE FUNCTION decrement_ai_credits(p_user_id UUID, p_credits INT)
RETURNS BOOLEAN LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE
  v_current_credits INT;
BEGIN
  SELECT ai_credits INTO v_current_credits
  FROM profiles WHERE id = p_user_id FOR UPDATE;

  IF v_current_credits < p_credits THEN
    RETURN FALSE;
  END IF;

  UPDATE profiles
  SET ai_credits = ai_credits - p_credits,
      updated_at = NOW()
  WHERE id = p_user_id;

  RETURN TRUE;
END;
$$;
```

