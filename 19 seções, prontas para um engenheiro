```typescript
// src/hooks/useAutosave.ts
import { useEffect, useRef } from 'react';
import { useEditorStore } from '@/stores/editorStore';
import { projectsService } from '@/services/projects.service';

const AUTOSAVE_INTERVAL_MS = 3000; // 3 segundos após última mudança

export function useAutosave() {
  const { projectId, activeModule, saveStatus, setSaveStatus, toJSON } = useEditorStore();
  const timerRef = useRef<ReturnType<typeof setTimeout>>();

  useEffect(() => {
    if (saveStatus !== 'unsaved' || !projectId) return;

    clearTimeout(timerRef.current);
    timerRef.current = setTimeout(async () => {
      setSaveStatus('saving');
      try {
        await projectsService.saveDiagram(projectId, toJSON(), activeModule);
        setSaveStatus('saved');
      } catch {
        setSaveStatus('unsaved'); // Retry na próxima mudança
      }
    }, AUTOSAVE_INTERVAL_MS);

    return () => clearTimeout(timerRef.current);
  }, [saveStatus]);
}
