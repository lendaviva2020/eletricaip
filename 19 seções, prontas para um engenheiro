## FASE 2 — DASHBOARD E GESTÃO DE PROJETOS

**Objetivo:** Dashboard funcional com CRUD de projetos.
**Duração estimada:** 4–6 dias.

### Passo 2.1 — Serviço de Projetos
```typescript
// src/services/projects.service.ts
import { supabase } from './supabase';
import type { Database } from '@/types/supabase.types';

type Project = Database['public']['Tables']['projects']['Row'];
type ProjectInsert = Database['public']['Tables']['projects']['Insert'];

export const projectsService = {
  async getAll(userId: string): Promise<Project[]> {
    const { data, error } = await supabase
      .from('projects')
      .select('*')
      .eq('owner_id', userId)
      .eq('is_archived', false)
      .order('updated_at', { ascending: false });

    if (error) throw new Error(`Erro ao buscar projetos: ${error.message}`);
    return data ?? [];
  },

  async create(payload: Omit<ProjectInsert, 'owner_id'>, userId: string): Promise<Project> {
    // Verificar limite do plano Free (máx 3 projetos)
    const { count } = await supabase
      .from('projects')
      .select('*', { count: 'exact', head: true })
      .eq('owner_id', userId)
      .eq('is_archived', false);

    const { data: profile } = await supabase
      .from('profiles')
      .select('plan')
      .eq('id', userId)
      .single();

    if (profile?.plan === 'free' && (count ?? 0) >= 3) {
      throw new Error('PLAN_LIMIT_REACHED');
    }

    const { data, error } = await supabase
      .from('projects')
      .insert({ ...payload, owner_id: userId })
      .select()
      .single();

    if (error) throw new Error(`Erro ao criar projeto: ${error.message}`);
    return data;
  },

  async update(id: string, payload: Partial<Project>): Promise<void> {
    const { error } = await supabase
      .from('projects')
      .update(payload)
      .eq('id', id);
    if (error) throw new Error(`Erro ao atualizar projeto: ${error.message}`);
  },

  async duplicate(projectId: string, userId: string): Promise<Project> {
    const { data: original, error: fetchError } = await supabase
      .from('projects')
      .select('*')
      .eq('id', projectId)
      .single();

    if (fetchError || !original) throw new Error('Projeto não encontrado');

    return projectsService.create({
      name: `${original.name} (Cópia)`,
      description: original.description,
      default_voltage: original.default_voltage,
      default_frequency: original.default_frequency,
      norm_standard: original.norm_standard,
      diagram_data: original.diagram_data,
    }, userId);
  },

  async archive(id: string): Promise<void> {
    await projectsService.update(id, { is_archived: true });
  },

  async saveDiagram(projectId: string, diagramData: object, module: string): Promise<void> {
    const { error } = await supabase.rpc('update_diagram_module', {
      p_project_id: projectId,
      p_module: module,
      p_data: diagramData,
    });
    if (error) throw new Error(`Erro ao salvar diagrama: ${error.message}`);
  },
