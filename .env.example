# =============================================================================
# EletricAI Industrial OS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your-project-id
SUPABASE_SERVICE_ROLE_KEY=eyJ... (server-only, NEVER prefix with NEXT_PUBLIC_)

# ---------------------------------------------------------------------------
# DeepSeek AI (required for AI features)
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# ---------------------------------------------------------------------------
# Stripe (required for billing)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_URL=https://your-domain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# ---------------------------------------------------------------------------
# Mercado Pago (required for billing - Brazil)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-...
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_CLIENT_ID=...
MERCADO_PAGO_CLIENT_SECRET=...
MERCADO_PAGO_WEBHOOK_SECRET=...

# ---------------------------------------------------------------------------
# QStash (required for async tasks / cron)
# ---------------------------------------------------------------------------
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_TOKEN=...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PUBLIC_APP_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Optional: OAuth
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
