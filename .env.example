# Supabase Configuration
# The URL of your Supabase project (can be found in Project Settings -> API)
VITE_SUPABASE_URL=your-supabase-url

# The public anon key for your Supabase project (can be found in Project Settings -> API)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# The project ID of your Supabase project (e.g. from the URL dashboard.supabase.com/project/xxxx)
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id

# Supabase Service Role Key (used only on the server, NEVER expose this to the frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# DeepSeek Integration
# Your DeepSeek API key for AI generation (e.g. sk-...)
DEEPSEEK_API_KEY=your-deepseek-api-key
